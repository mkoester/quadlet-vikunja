# Local overrides — values here take precedence over vikunja.env.

# Required: public URL of your Vikunja instance (include trailing slash)
#VIKUNJA_SERVICE_PUBLICURL=https://vikunja.example.com/

# Once all users have registered, disable open registration:
#VIKUNJA_SERVICE_ENABLEREGISTRATION=false

# Required: secret key for JWT tokens (generate with: openssl rand -hex 32)
# Without this, all sessions are invalidated on every container restart.
#VIKUNJA_SERVICE_JWTSECRET=
